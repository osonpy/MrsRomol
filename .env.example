# ──────────────────────────────────────────────────────────────────────────────
# Misr Romol — Environment Variables
# 1. Copy: cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to git!
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal Telegram user ID (get it from @userinfobot)
# Used for admin notifications and /admin commands
ADMIN_GROUP_ID=123456789

# Comma-separated personal Telegram user IDs that can use admin commands
# Example: ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=123456789

# ALL chat IDs that receive order/payment notifications (group + personal)
# Format: ADMIN_NOTIFY_IDS=-1001234567890,123456789
# If not set, defaults to ADMIN_GROUP_ID only
ADMIN_NOTIFY_IDS=-1001234567890,123456789

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Storage bucket name for payment receipts (create it in Dashboard → Storage)
RECEIPTS_BUCKET=receipts

# ── Mini App ──────────────────────────────────────────────────────────────────
# URL where the React Mini App is hosted.
# Local dev: use cloudflare tunnel (see instructions below)
# Production: your Vercel/Netlify URL
MINI_APP_URL=https://your-tunnel.trycloudflare.com

# ── API / CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the FastAPI backend
ALLOWED_ORIGINS=https://your-tunnel.trycloudflare.com,http://localhost:5173

# Secret key for X-Admin-Key header (admin API endpoints).
# Generate a strong random string for production!
ADMIN_SECRET_KEY=change-me-in-production

# Backward-compat alias (same value as ADMIN_SECRET_KEY)
INTERNAL_SECRET=change-me-in-production

# ── Business logic ────────────────────────────────────────────────────────────
# Payment card number shown to customers in order confirmations
PAYMENT_CARD=0000000000000000

# ── Development ───────────────────────────────────────────────────────────────
# DEV_MODE=true allows "mock_init_data_for_dev" as valid initData (browser testing)
# Set to false in production!
DEV_MODE=true
